# Discord webhook — create one in Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Gmail SMTP — use an App Password, NOT your regular Gmail password
# Enable 2FA first, then generate one at: https://myaccount.google.com/apppasswords
EMAIL_FROM=you@gmail.com
EMAIL_TO=alerts@example.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
